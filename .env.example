# Copy to .env and fill in the values. GrabWise tries AWS Bedrock first and
# falls back to Anthropic direct if Bedrock errors. Configure BOTH for the
# Bedrock-with-failsafe pattern; either one alone also works.

# =============================================================================
# AWS Bedrock (primary)
# =============================================================================
# Region with Anthropic Claude model access enabled. us-west-2 and us-east-1
# are the broadest. You must request model access in the Bedrock console first:
# Console → Bedrock → "Model access" (left sidebar) → "Request model access".
AWS_REGION=us-west-2

# Long-term IAM user credentials OR STS temporary credentials (in which case
# AWS_SESSION_TOKEN below is required).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only required for STS / Identity Center / SSO temporary creds. Leave blank for long-term IAM users.
AWS_SESSION_TOKEN=
# Model IDs available in your region. List with:
#   aws bedrock list-foundation-models --region us-west-2 --by-output-modality TEXT \
#       --query 'modelSummaries[?contains(modelId, `anthropic`)].modelId'
#
# Newer models may require an inference-profile prefix (e.g. "us." for cross-region).
# Examples:
#   anthropic.claude-3-5-sonnet-20241022-v2:0
#   us.anthropic.claude-3-5-sonnet-20241022-v2:0
#   anthropic.claude-3-5-haiku-20241022-v1:0
#   us.anthropic.claude-sonnet-4-20250514-v1:0
#   us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_SONNET=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_MODEL_HAIKU=anthropic.claude-haiku-4-5-20251001-v1:0

# =============================================================================
# Anthropic direct API (failsafe — used when Bedrock errors)
# =============================================================================
# Get a key at console.anthropic.com → API Keys. NOTE: this is separate from a
# Claude Pro subscription; you need API credits in the developer console.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-5
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5

# =============================================================================
# Database
# =============================================================================
# SQLite for hackathon dev. Swap to postgresql+psycopg://... in prod.
DATABASE_URL=sqlite:///./grabwise.db

# =============================================================================
# Misc
# =============================================================================
LOG_LEVEL=INFO
